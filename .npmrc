# ─────────────────────────────────────────────
# SecureSupply — configuración de pnpm
# ─────────────────────────────────────────────

# Fija versiones exactas al agregar dependencias (sin ^ ni ~)
# Ver: https://docs.npmjs.com/cli/v11/configuring-npm/npmrc#save-exact
save-exact=true

# Bloquea todos los scripts postinstall por seguridad.
# Excepción: Prisma Generate necesita ejecutarse.
#   Después de pnpm install, ejecutar manualmente:
#     pnpm -w prisma generate
ignore-scripts=true

# Exige que la versión del gestor de paquetes coincida con packageManager
engine-strict=true

# Deshabilita la verificación de antigüedad mínima de paquetes en el lockfile
# (necesario porque el monorepo usa versiones exactas recién publicadas)
minimumReleaseAge=0
