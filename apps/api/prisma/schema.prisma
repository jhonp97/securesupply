// ─────────────────────────────────────────────
// Esquema de Prisma — SecureSupply API
// ─────────────────────────────────────────────
// La URL de conexión se define en prisma.config.ts
// via env('DATABASE_URL'). NO incluir url aquí.
// Se usa adapter-pg (driver adapter nativo).
// ─────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // url NO se define aquí — se gestiona en prisma.config.ts
  // adapter se pasa programáticamente via PrismaPg en prisma.service.ts
}

// ── Enumeraciones ──────────────────────────────

enum Role {
  ADMIN
  ANALYST
  VIEWER
}

enum ScanStatus {
  QUEUED
  CLONING
  SCANNING
  COMPLETED
  FAILED
  CANCELLED
}

enum TriggerType {
  WEBHOOK
  MANUAL
  SCHEDULED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Severity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ScannerType {
  SECRETS
  DEPENDENCIES
  LICENSES
  MALWARE
  CODE_QUALITY
}

// ── Modelos ────────────────────────────────────

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  role          Role           @default(VIEWER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  refreshTokens RefreshToken[]
  repositories  Repository[]

  @@index([email])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique // SHA-256 para búsqueda rápida
  token     String            // bcrypt para verificación
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
}

model Repository {
  id            String    @id @default(cuid())
  githubId      Int       @unique // ID numérico de GitHub
  fullName      String    @unique // formato: owner/repo
  defaultBranch String    @default("main")
  isPrivate     Boolean   @default(false)
  installationId Int?     // ID de instalación de GitHub App
  ownerId       String
  owner         User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  scanJobs      ScanJob[]

  @@index([ownerId])
  @@index([fullName])
  @@index([installationId])
}

model ScanJob {
  id           String      @id @default(cuid())
  repositoryId String
  repository   Repository  @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  status       ScanStatus  @default(QUEUED)
  triggerType  TriggerType
  gitRef       String      @default("main") // rama o ref escaneada
  errorMessage String?
  retryCount   Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  result       ScanResult?

  @@index([repositoryId])
  @@index([status])
  @@index([createdAt])
}

model ScanResult {
  id        String    @id @default(cuid())
  scanJobId String    @unique // relación 1:1 con ScanJob
  scanJob   ScanJob   @relation(fields: [scanJobId], references: [id], onDelete: Cascade)
  riskScore Int       @default(0)
  riskLevel RiskLevel @default(LOW)
  summary   Json?     // resumen estructurado en JSON
  findings  Finding[]
  createdAt DateTime  @default(now())

  @@index([riskLevel])
}

model Finding {
  id           String       @id @default(cuid())
  scanResultId String
  scanResult   ScanResult   @relation(fields: [scanResultId], references: [id], onDelete: Cascade)
  scanner      ScannerType
  severity     Severity
  findingId    String       // ID externo del hallazgo (del scanner)
  title        String
  description  String
  filePath     String?
  lineNumber   Int?
  metadata     Json?        // metadatos adicionales del scanner
  createdAt    DateTime     @default(now())

  @@index([scanResultId])
  @@index([severity])
  @@index([scanner])
}
