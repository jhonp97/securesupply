# ─────────────────────────────────────────────
# Variables de Entorno — SecureSupply
# ─────────────────────────────────────────────
# Copia este archivo a .env y completa los
# valores reales. NUNCA commitees .env.
# ─────────────────────────────────────────────

# Conexión a PostgreSQL (Prisma 7)
DATABASE_URL=postgresql://your-user:your-password@localhost:5432/securesupply

# Conexión a Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Entorno de ejecución
NODE_ENV=development

# Puerto del servidor API
PORT=4000

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:3000
