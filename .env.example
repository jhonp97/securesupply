# ─────────────────────────────────────────────
# Variables de Entorno — SecureSupply
# ─────────────────────────────────────────────
# Copia este archivo a .env y completa los
# valores reales. NUNCA commitees .env.
# ─────────────────────────────────────────────

# Conexión a PostgreSQL (Prisma 7)
DATABASE_URL=postgresql://your-user:your-password@localhost:5432/securesupply

# Conexión a Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Entorno de ejecución
NODE_ENV=development

# Puerto del servidor API
PORT=4000

 # URL del frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# ── Seguridad ──
# JWT: mínimo 32 caracteres, genera con: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-min-32-chars-long
REFRESH_TOKEN_SECRET=your-refresh-secret-min-32-chars-different

# GitHub App (opcional para Phase 2, obligatorio para Phase 3)
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your-webhook-secret-min-20-chars

# ── Límites operacionales ──
SCANNER_TIMEOUT_MS=300000
MAX_REPO_SIZE_MB=500
WORKER_CONCURRENCY=2
